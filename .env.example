# Login password for the dashboard
TPP_PASSWORD=change-me

# Optional: distinct secret for signing the session cookie.
# Defaults to TPP_PASSWORD if unset, but setting a separate value is recommended.
TPP_SESSION_SECRET=

# Vercel Postgres (or any Postgres-compatible) connection.
# When deploying on Vercel, this is provisioned automatically.
POSTGRES_URL=

# Anthropic API key for the /api/ai route (triage, leadership update, task summary).
ANTHROPIC_API_KEY=
